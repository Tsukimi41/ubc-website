# Public origin. Production must use an HTTPS origin only (no path/query/fragment).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Additional exact browser origins, comma-separated. Usually blank in production.
ALLOWED_ORIGINS=

# Feature flags (keep false until university/professor approval)
ENABLE_SECRET_SHOP=false
ENABLE_SALON=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared rate limiting. Leave RATE_LIMIT_BACKEND=memory only for local development.
# Production requires database plus a random secret containing at least 32 bytes.
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_HMAC_SECRET=
# Vercel is detected automatically. Set only when another trusted reverse proxy is used.
# Allowed values: x-forwarded-for, x-real-ip, x-vercel-forwarded-for
TRUSTED_PROXY_IP_HEADER=

# IoT HMAC authentication. Each key is restricted to one hive UUID.
# Generate an independent random secret (>=32 bytes) for every sensor device.
# Shape: {"sensor-a":{"hiveId":"<uuid>","secret":"<random-secret>"}}
# The empty object intentionally fails closed until real credentials are added.
IOT_INGEST_KEYS={}
IOT_SIGNATURE_TOLERANCE_SECONDS=300
IOT_MAX_READING_AGE_SECONDS=604800

# CMS
NOTION_TOKEN=
NOTION_DATABASE_ID=
TUMBLR_API_KEY=
TUMBLR_BLOG_IDENTIFIER=
# External links and images are omitted unless their host is explicitly listed.
NOTION_ALLOWED_LINK_HOSTS=www.notion.so
TUMBLR_ALLOWED_LINK_HOSTS=
CMS_IMAGE_HOSTS=64.media.tumblr.com,prod-files-secure.s3.us-west-2.amazonaws.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# A unique non-secret namespace used to reject events from unrelated applications.
STRIPE_METADATA_APP_ID=urban-bee-club
# false for Stripe Test mode; true for production Live mode.
STRIPE_EXPECT_LIVE_MODE=false
STRIPE_SALON_PRICE_ID=
# Create the member coupon in Stripe and configure its ID here.
STRIPE_SALON_COUPON_ID=
STRIPE_HONEY_PRICE_ID=
STRIPE_CREAM_PRICE_ID=
STRIPE_LIP_PRICE_ID=
# Used to derive stable, non-guessable member codes. At least 32 random bytes.
DISCOUNT_CODE_HMAC_SECRET=
DISCOUNT_CODE_PREFIX=BEE

# Optional contact notification webhook. URL host must also be explicitly allowed.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_ALLOWED_HOSTS=
